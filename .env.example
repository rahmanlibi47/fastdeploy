########################################
# Repository
########################################

GITHUB_REPO="https://github.com/YOUR_USERNAME/YOUR_REPO.git"
PROJECT_NAME="myapp"

########################################
# Project Structure
########################################

FRONTEND_DIR="frontend"
BACKEND_DIR="server"

########################################
# Backend
########################################

APP_MODULE="main:app"
SERVICE_NAME="myapp"
PORT=8000
VENV_NAME="venv"

########################################
# Frontend
########################################

BUILD_DIR="dist"

########################################
# Nginx
########################################

DOMAIN="_"
NGINX_ROOT="/var/www/myapp"

########################################
# Python
########################################

PYTHON="python3"

########################################
# Node
########################################

NODE_MAJOR=22